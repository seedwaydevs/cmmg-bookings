generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  role     UserRole @default(ADMIN)
}

model Booking {
  id                         String         @id @default(cuid())
  service                    BookingService @default(STUDIO)
  date                       DateTime
  bookingName                String
  bookingSurname             String
  email                      String
  idCopy                     String?
  packageId                  String
  durationMinutes            Int
  priceCents                 Int
  currency                   String         @default("ZAR")
  status                     BookingStatus  @default(PENDING)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  extras                     Json?
  extrasCents                Int?
  grandTotalCents            Int?
  bundleEligibilityConfirmed Boolean        @default(false)
  packageCategory            String         @default("")
  packageDescription         String?
  packageDurationLabel       String         @default("")
  packageIncludes            String[]       @default([])
  packageName                String         @default("")
  package                    ServicePackage @relation(fields: [packageId], references: [id])
  invoice                    Invoice?

  @@index([email])
}

model Invoice {
  id            String        @id @default(cuid())
  bookingId     String        @unique
  number        String        @unique
  status        InvoiceStatus @default(ISSUED)
  subtotalCents Int
  vatCents      Int           @default(0)
  totalCents    Int
  currency      String        @default("ZAR")
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  booking       Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model ServicePackage {
  id                               String         @id @default(cuid())
  service                          BookingService
  minutes                          Int
  priceCents                       Int
  currency                         String         @default("ZAR")
  isActive                         Boolean        @default(true)
  createdAt                        DateTime       @default(now())
  updatedAt                        DateTime       @updatedAt
  category                         String         @default("")
  description                      String?
  displayOrder                     Int            @default(0)
  durationLabel                    String         @default("")
  includes                         String[]       @default([])
  isBookableOnline                 Boolean        @default(true)
  name                             String         @default("")
  requiresPaidFullDayStudioBooking Boolean        @default(false)
  slug                             String?        @unique
  bookings                         Booking[]

  @@index([service, isActive, isBookableOnline, displayOrder])
}

enum UserRole {
  ADMIN
}

enum BookingService {
  STUDIO
  GREENSCREEN
  SOUNDMIXING
  FINALMIX
}

enum BookingStatus {
  PENDING
  CONFIRMED
  FULFILLED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}
